{
  "expo": {
    "name": "Sparkles",
    "slug": "sparkles",
    "version": "1.0.0",
    "scheme": "sparkles",
    "newArchEnabled": true,
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      "expo-file-system",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Sparkles to access your microphone to record ideas."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
